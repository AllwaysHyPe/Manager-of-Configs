# backend.tfvars.example
# Copy to backend.tfvars and update with your values
# backend.tfvars is gitignored — never commit it
#
# Create the storage account manually before running terraform init:
#   az group create -n rg-mgr-of-configs-state -l westus
#   az storage account create -n samgrofconfigs -g rg-mgr-of-configs-state --sku Standard_LRS
#   az storage container create -n tfstate --account-name samgrofconfigs
# then terraform init "-backend-config=backend.tfvars"


resource_group_name  = "mgr-of-configs"
storage_account_name = "mgrofconfigs"
container_name       = "tfstate"
key                  = "mgr-of-configs.terraform.tfstate"